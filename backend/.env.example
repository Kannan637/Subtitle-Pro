# SubtitleAI Pro — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Use MongoDB Atlas connection string for production.
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=subtitleai_pro

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Path to your downloaded service account JSON (DO NOT commit that file).
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_AUTH_CLOCK_SKEW_SECONDS=60

# ─── Groq AI (Whisper transcription) ─────────────────────────────────────────
# Get your key from: https://console.groq.com
GROQ_API_KEY=gsk_...

# ─── Pexels API (B-roll footage) ─────────────────────────────────────────────
# Get your key from: https://www.pexels.com/api/
PEXELS_API_KEY=...

# ─── LemonSqueezy Payments ────────────────────────────────────────────────────
# REQUIRED: Set this before accepting any payments.
# Without it, ANYONE can upgrade users for free via a crafted POST request.
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# Server-side checkout creation. Keep this key in the backend only.
LEMONSQUEEZY_API_KEY=your-lemon-squeezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_TEST_MODE=false

# Map your LemonSqueezy variant IDs to plan names (from your LS dashboard)
LS_CREATOR_VARIANT_ID=
LS_STUDIO_VARIANT_ID=

# Public frontend origin used in Lemon Squeezy success redirects.
FRONTEND_APP_URL=http://localhost:5173

# --- Social Scheduler OAuth ---
# Public backend API base used for OAuth callbacks. Production example:
# https://yourdomain.com/api/v1
SOCIAL_OAUTH_API_BASE_URL=http://localhost:8000/api/v1
# Required before storing connected social tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SOCIAL_OAUTH_TOKEN_SECRET=

# Register this redirect URI in each provider:
# {SOCIAL_OAUTH_API_BASE_URL}/social-scheduler/oauth/{platform_id}/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=
META_GRAPH_VERSION=v22.0
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
THREADS_OAUTH_CLIENT_ID=
THREADS_OAUTH_CLIENT_SECRET=
SOCIAL_SCHEDULER_ENABLED=true
SOCIAL_SCHEDULER_POLL_SECONDS=30
SOCIAL_SCHEDULER_BATCH_SIZE=10
SOCIAL_SCHEDULER_PUBLISH_PRIVACY_STATUS=public

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (NO trailing slashes).
# Dev:  http://localhost:5173,http://localhost:3000
# Prod: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional regex for preview domains, e.g. https://.*\.vercel\.app
CORS_ALLOW_ORIGIN_REGEX=

# ─── Upload Limits ────────────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 2 GB)
MAX_UPLOAD_SIZE_BYTES=2147483648

# ─── Redis (future async queue) ───────────────────────────────────────────────
# Leave empty if not using background tasks yet.
REDIS_URL=
