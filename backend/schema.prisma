generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  name             String?
  avatarUrl        String?
  plan             Plan         @default(FREE)
  creditsRemaining Int          @default(3600) // 60 minutes in seconds
  isVerified       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  projects         Project[]
  subscriptions    Subscription[]
  creditLedger     CreditLedger[]
}

enum Plan {
  FREE
  CREATOR
  STUDIO
  ENTERPRISE
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String
  status      JobStatus @default(PENDING)
  durationSec Float?
  thumbnailUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaFiles  MediaFile[]
  jobs        Job[]
  tracks      SubtitleTrack[]
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETE
  ERROR
}

model MediaFile {
  id          String   @id @default(uuid())
  projectId   String
  fileName    String
  fileUrl     String
  fileType    String
  sizeBytes   BigInt
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Job {
  id          String   @id @default(uuid())
  projectId   String
  type        JobType
  status      JobStatus @default(PENDING)
  modelUsed   String?
  errorMsg    String?
  progress    Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum JobType {
  TRANSCRIPTION
  TRANSLATION
  MEDIA_PROCESSING
  BURN_IN
}

model SubtitleTrack {
  id           String   @id @default(uuid())
  projectId    String
  languageCode String
  isOriginal   Boolean  @default(true)
  createdBy    String   @default("ai") // "ai" or "human"
  version      Int      @default(1)
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cues         SubtitleCue[]
}

model SubtitleCue {
  id           String   @id @default(uuid())
  trackId      String
  sequence     Int
  startMs      Int
  endMs        Int
  text         String
  speakerId    String?
  confidence   Float?
  linePosition String?

  track        SubtitleTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId, startMs])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 Plan     @default(FREE)
  status               String
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id          String   @id @default(uuid())
  userId      String
  amount      Int      // Positive for additions, negative for deductions
  reason      String
  jobId       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
